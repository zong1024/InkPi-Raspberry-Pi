        <mxCell id="main_score_note" parent="1" value="&lt;b&gt;主分过渡策略&lt;/b&gt;&lt;br&gt;现有 ONNX 继续输出 total_score&lt;br&gt;quality_features / calibration 继续保留&lt;br&gt;rubric_preview_total 仅用于内部验证&lt;br&gt;先立标准，后切主分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F3E6;strokeColor=#B9AC8F;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="360" y="500" width="270" height="220" as="geometry" />
