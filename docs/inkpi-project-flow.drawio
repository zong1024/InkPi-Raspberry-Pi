<mxfile host="app.diagrams.net" agent="Codex" version="29.6.6" type="device">
  <diagram id="inkpi-project-flow" name="InkPi Project Flow">
    <mxGraphModel dx="2377" dy="1238" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" value="&lt;b&gt;InkPi 双书体项目全流程（楷书 + 行书）&lt;/b&gt;&lt;br&gt;主链：入口 → 预处理 → OCR → 用户选择书体 → 对应主分模型 / 四维解释 → EvaluationResult → 本地落库 → 云端同步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1C1816;strokeColor=#1C1816;fontColor=#FFFFFF;fontStyle=1;fontSize=22;align=center;" vertex="1">
          <mxGeometry x="20" y="20" width="2160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sec_input" parent="1" value="1. 输入与入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6EDF8;strokeColor=#8AA0BE;fontStyle=1;fontSize=18;align=center;" vertex="1">
          <mxGeometry x="40" y="110" width="260" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sec_runtime" parent="1" value="2. 本地评测主链" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE9D6;strokeColor=#D79B4B;fontStyle=1;fontSize=18;align=center;" vertex="1">
          <mxGeometry x="340" y="110" width="1340" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sec_cloud" parent="1" value="3. 存储 / 同步 / 云端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D9D7;strokeColor=#B55B54;fontStyle=1;fontSize=18;align=center;" vertex="1">
          <mxGeometry x="1710" y="110" width="450" height="42" as="geometry" />
        </mxCell>
        <mxCell id="desktop" parent="1" value="&lt;b&gt;PyQt 正式界面&lt;/b&gt;&lt;br&gt;main.py&lt;br&gt;views/home_view.py&lt;br&gt;views/camera_view.py&lt;br&gt;views/result_view.py&lt;br&gt;主分 + 四维解释分，不显示 debug" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9E8FB;strokeColor=#6C8EBF;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="50" y="190" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="webui" parent="1" value="&lt;b&gt;WebUI 调试端&lt;/b&gt;&lt;br&gt;web_ui/app.py&lt;br&gt;index.html + app.js&lt;br&gt;拍照 / 上传 / 历史 / 详情&lt;br&gt;详情页显示 score_debug" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9E8FB;strokeColor=#6C8EBF;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="50" y="350" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="input" parent="1" value="&lt;b&gt;图像输入&lt;/b&gt;&lt;br&gt;摄像头预览 / 拍照&lt;br&gt;本地图片上传&lt;br&gt;统一进入单字评测链路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C9;strokeColor=#D3AA4A;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="50" y="520" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="preprocess" parent="1" value="&lt;b&gt;PreprocessingService&lt;/b&gt;&lt;br&gt;预检、透视校正、去网格、主体提取&lt;br&gt;产出 processed_image + ocr_image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="360" y="290" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ocr" parent="1" value="&lt;b&gt;LocalOcrService&lt;/b&gt;&lt;br&gt;PaddleOCR 本地识别&lt;br&gt;输出 character + confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEFD9;strokeColor=#82B366;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="710" y="170" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="quality" parent="1" value="&lt;b&gt;QualityScorerService&lt;/b&gt;&lt;br&gt;按 script 路由双 ONNX 主分模型&lt;br&gt;regular → quality_scorer_regular.onnx&lt;br&gt;running → quality_scorer_running.onnx&lt;br&gt;输出 total_score / quality_level / quality_confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEFD9;strokeColor=#82B366;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1040" y="150" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="dimension" parent="1" value="&lt;b&gt;DimensionScorerService&lt;/b&gt;&lt;br&gt;复用 quality_features + geometry_features + calibration&lt;br&gt;输出 structure / stroke / integrity / stability&lt;br&gt;并生成 strongest / weakest 解释" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF6EA;strokeColor=#82B366;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1040" y="360" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="evaluation" parent="1" value="&lt;b&gt;EvaluationService&lt;/b&gt;&lt;br&gt;编排 processed_image + ocr_image&lt;br&gt;校验用户显式传入 script&lt;br&gt;调用 OCR / script 主分 / script 解释层&lt;br&gt;生成统一 EvaluationResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7D7EE;strokeColor=#9673A6;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="710" y="330" width="260" height="130" as="geometry" />
        </mxCell>
        <mxCell id="result" parent="1" value="&lt;b&gt;EvaluationResult&lt;/b&gt;&lt;br&gt;script / script_label&lt;br&gt;total_score / quality_level / feedback&lt;br&gt;character_name / quality_confidence&lt;br&gt;dimension_scores / score_debug" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7D7EE;strokeColor=#9673A6;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="710" y="550" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="database" parent="1" value="&lt;b&gt;DatabaseService&lt;/b&gt;&lt;br&gt;本地 SQLite&lt;br&gt;新增 script&lt;br&gt;新增 dimension_scores_json&lt;br&gt;新增 score_debug_json&lt;br&gt;旧记录回填 regular" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D4D3;strokeColor=#B85450;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1080" y="560" width="270" height="140" as="geometry" />
        </mxCell>
        <mxCell id="sync" parent="1" value="&lt;b&gt;CloudSyncService&lt;/b&gt;&lt;br&gt;upload_result_async()&lt;br&gt;上传主分、四维分和 debug JSON&lt;br&gt;POST /api/device/results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8D4D3;strokeColor=#B85450;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1420" y="570" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="qt_result" parent="1" value="&lt;b&gt;Qt 结果页&lt;/b&gt;&lt;br&gt;正式展示端&lt;br&gt;显示主分、等级、反馈、四维卡片&lt;br&gt;不显示 score_debug" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9E8FB;strokeColor=#6C8EBF;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="350" y="860" width="260" height="130" as="geometry" />
        </mxCell>
        <mxCell id="webui_debug" parent="1" value="&lt;b&gt;WebUI 详情页&lt;/b&gt;&lt;br&gt;调试展示端&lt;br&gt;历史列表显示四维摘要&lt;br&gt;详情页展开 probabilities / quality_features /&lt;br&gt;geometry_features / calibration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9E8FB;strokeColor=#6C8EBF;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="680" y="850" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="miniapp" parent="1" value="&lt;b&gt;MiniApp 结果详情&lt;/b&gt;&lt;br&gt;小程序只显示四维解释分和主反馈&lt;br&gt;历史列表保持轻量&lt;br&gt;不展示 score_debug" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEFD9;strokeColor=#82B366;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1100" y="860" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="cloud_api" parent="1" value="&lt;b&gt;Cloud API&lt;/b&gt;&lt;br&gt;cloud_api/app.py&lt;br&gt;列表 / 详情 / 方法论接口全部返回 script&lt;br&gt;列表支持 script filter&lt;br&gt;方法论返回 supported_scripts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7D7EE;strokeColor=#9673A6;fontSize=14;fontColor=#241E1A;" vertex="1">
