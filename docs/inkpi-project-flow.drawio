        <mxCell id="main_score_note" parent="1" value="&lt;b&gt;主分校准细节&lt;/b&gt;&lt;br&gt;quality_features:&lt;br&gt;fg_ratio / bbox_ratio / center_quality /&lt;br&gt;component_norm / edge_touch / texture_std&lt;br&gt;&lt;br&gt;calibration:&lt;br&gt;feature_quality / probability_margin /&lt;br&gt;quality_confidence_norm / score_range_fit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F3E6;strokeColor=#B9AC8F;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="360" y="500" width="270" height="220" as="geometry" />
        </mxCell>
        <mxCell id="dimension_note" parent="1" value="&lt;b&gt;四维解释分规则&lt;/b&gt;&lt;br&gt;结构 = center_quality + bbox_ratio_band + projection_balance + bbox_fill_band&lt;br&gt;笔画 = texture_std_band + orientation_concentration + ink_ratio_band + component_norm_band&lt;br&gt;完整 = ocr_confidence + dominant_share + (1-edge_touch) + subject_edge_safe&lt;br&gt;稳定 = quality_confidence + probability_margin + feature_quality + score_range_fit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F3E6;strokeColor=#B9AC8F;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="360" y="760" width="1180" height="150" as="geometry" />
        </mxCell>
