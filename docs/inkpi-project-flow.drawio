        <mxCell id="training" parent="1" value="&lt;b&gt;训练链路（本机 V100）&lt;/b&gt;&lt;br&gt;build_quality_manifest.py --script regular|running&lt;br&gt;train_quality_scorer.py --script regular|running&lt;br&gt;分别导出楷书 / 行书 ONNX + metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C9;strokeColor=#D3AA4A;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1780" y="780" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="model_artifact" parent="1" value="&lt;b&gt;模型与静态资产&lt;/b&gt;&lt;br&gt;models/quality_scorer_regular.onnx&lt;br&gt;models/quality_scorer_regular.metrics.json&lt;br&gt;models/quality_scorer_running.onnx&lt;br&gt;models/quality_scorer_running.metrics.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C9;strokeColor=#D3AA4A;fontSize=14;fontColor=#241E1A;" vertex="1">
          <mxGeometry x="1780" y="950" width="320" height="110" as="geometry" />
