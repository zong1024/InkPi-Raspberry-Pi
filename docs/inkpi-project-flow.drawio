        <mxCell id="cloud_db" parent="1" value="&lt;b&gt;CloudDatabase&lt;/b&gt;&lt;br&gt;cloud_api/storage.py&lt;br&gt;results 表新增&lt;br&gt; dimension_scores_json / score_debug_json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7D7EE;strokeColor=#9673A6;fontSize=14;fontColor=#241E1A;" vertex="1">
