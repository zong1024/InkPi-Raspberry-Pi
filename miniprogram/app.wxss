/* app.wxss - 全局样式 */

/* 主题色变量 */
page {
  --primary: #e03229;
  --primary-light: #ff4d44;
  --primary-dark: #b82821;
  --background: #f8f6f6;
  --background-dark: #211211;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #eeeeee;
  --white: #ffffff;
  
  font-family: "Microsoft YaHei", "SimSun", -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: var(--background);
  color: var(--text-color);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 宣纸纹理背景 */
.xuan-paper {
  background-image: 
    radial-gradient(circle at 50% 50%, rgba(255,255,255,0.2) 0%, transparent 100%),
    linear-gradient(to right, rgba(0,0,0,0.02) 1rpx, transparent 1rpx),
    linear-gradient(to bottom, rgba(0,0,0,0.02) 1rpx, transparent 1rpx);
  background-size: 100% 100%, 40rpx 40rpx, 40rpx 40rpx;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(224, 50, 41, 0.1);
}

/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: var(--primary);
  color: var(--white);
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(224, 50, 41, 0.3);
}

.btn-primary:active {
  background-color: var(--primary-dark);
  transform: scale(0.98);
}

/* 次要按钮 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: rgba(224, 50, 41, 0.1);
  color: var(--primary);
  font-size: 32rpx;
  font-weight: medium;
  border-radius: 16rpx;
  border: 1rpx solid rgba(224, 50, 41, 0.2);
}

.btn-secondary:active {
  background-color: rgba(224, 50, 41, 0.2);
}

/* 分割线 */
.divider {
  width: 96rpx;
  height: 4rpx;
  background-color: rgba(224, 50, 41, 0.3);
  border-radius: 2rpx;
  margin: 32rpx 0;
}

/* 分数显示 */
.score-text {
  font-size: 72rpx;
  font-weight: bold;
  color: var(--primary);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  border-radius: 8rpx;
  background-color: rgba(224, 50, 41, 0.1);
  color: var(--primary);
}

.tag-success {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--background);
  border-bottom: 1rpx solid rgba(224, 50, 41, 0.1);
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  flex: 1;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(224, 50, 41, 0.05);
}

/* 图标 */
.icon {
  width: 48rpx;
  height: 48rpx;
}

.icon-large {
  width: 80rpx;
  height: 80rpx;
}

/* 底部安全区 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-hint);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty-state text {
  margin-top: 24rpx;
  font-size: 28rpx;
}