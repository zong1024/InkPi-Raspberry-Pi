<!-- pages/index/index.wxml -->
<view class="page">
  <view class="hero-card">
    <view class="hero-top">
      <view class="logo-dot"></view>
      <text class="brand">InkPi 墨韵评测</text>
    </view>
    <text class="title">书法智能评测</text>
    <text class="subtitle">云端主通道 · 树莓派可选加速</text>
  </view>

  <view class="status-card">
    <view class="status-row">
      <text class="status-label">云端状态</text>
      <text class="status-value cloud">{{cloudStatusText}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">树莓派状态</text>
      <text class="status-value {{isConnected ? 'ok' : 'warn'}}">{{connectionStatus}}</text>
    </view>
    <text class="status-detail">{{statusDetail}}</text>
    <view class="meta" wx:if="{{raspberryPiIP}}">
      <text>IP: {{raspberryPiIP}}</text>
      <text wx:if="{{latency}}">延迟: {{latency}}ms</text>
    </view>
  </view>

  <view class="action-card">
    <button class="btn btn-primary" bindtap="goToHistory">进入主界面</button>
    <view class="btn-row">
      <button class="btn btn-ghost" bindtap="onRefreshStatus" loading="{{isChecking}}">
        刷新树莓派状态
      </button>
      <button class="btn btn-ghost" bindtap="onShowIPSetting">设置IP</button>
    </view>
  </view>

  <view class="tips-card">
    <text class="tips-title">说明</text>
    <text class="tips-item">1. 不配置树莓派也可正常使用（走云端）</text>
    <text class="tips-item">2. 同局域网配置树莓派可作为加速通道</text>
    <text class="tips-item">3. 云端异常时会自动尝试树莓派兜底</text>
  </view>

  <view class="modal-mask" wx:if="{{showIPModal}}" bindtap="onHideIPSetting">
    <view class="modal" catchtap="preventClose">
      <text class="modal-title">设置树莓派 IP</text>
      <input
        class="ip-input"
        type="text"
        placeholder="例如 192.168.1.100"
        value="{{inputIP}}"
        bindinput="onIPInput"
      />
      <view class="modal-actions">
        <button class="btn btn-ghost" bindtap="onHideIPSetting">取消</button>
        <button class="btn btn-primary" bindtap="onConfirmIP">保存</button>
      </view>
    </view>
  </view>
</view>