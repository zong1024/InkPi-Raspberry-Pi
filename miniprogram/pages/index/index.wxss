/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #f6f8ff 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.hero-card,
.status-card,
.action-card,
.tips-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 41, 55, 0.08);
  margin-bottom: 20rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.logo-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #4f46e5;
  margin-right: 12rpx;
}

.brand {
  font-size: 26rpx;
  color: #4b5563;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.status-label {
  font-size: 26rpx;
  color: #374151;
}

.status-value {
  font-size: 24rpx;
  font-weight: 600;
}

.status-value.cloud {
  color: #2563eb;
}

.status-value.ok {
  color: #16a34a;
}

.status-value.warn {
  color: #d97706;
}

.status-detail {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.meta {
  margin-top: 14rpx;
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.btn {
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);
  color: #fff;
}

.btn-ghost {
  background: #f3f4f6;
  color: #374151;
}

.btn-row {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.8;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 86%;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.modal-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.ip-input {
  height: 84rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #111827;
}

.modal-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}