/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background-color: var(--background);
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--background);
  border-bottom: 1rpx solid rgba(224, 50, 41, 0.1);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon, .notify-icon {
  font-size: 40rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 用户卡片 */
.user-card {
  margin: 24rpx;
  padding: 48rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  border: 1rpx solid rgba(224, 50, 41, 0.05);
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(224, 50, 41, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(224, 50, 41, 0.1);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: var(--primary);
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 统计区域 */
.stats-section {
  display: flex;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  border: 1rpx solid rgba(224, 50, 41, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #e0e0e0;
  align-self: center;
}

/* 功能区域 */
.function-section {
  margin: 0 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.function-list {
  background-color: var(--white);
  border-radius: 16rpx;
  border: 1rpx solid rgba(224, 50, 41, 0.05);
}

.function-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background-color: rgba(224, 50, 41, 0.05);
}

.function-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(224, 50, 41, 0.05);
  border-radius: 12rpx;
  font-size: 32rpx;
}

.function-name {
  font-size: 28rpx;
  color: #333;
}

.function-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 退出登录 */
.logout-section {
  margin: 48rpx 24rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--white);
  color: var(--primary);
  font-size: 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(224, 50, 41, 0.2);
}