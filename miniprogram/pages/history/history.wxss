/* pages/history/history.wxss */

.history-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--background);
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--background);
  border-bottom: 1rpx solid rgba(224, 50, 41, 0.1);
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 连接状态栏 */
.connection-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  gap: 12rpx;
}

.connection-bar.connected {
  background: #e8f5e9;
}

.connection-bar.disconnected {
  background: #fff3e0;
}

.connection-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999;
}

.connection-bar.connected .connection-dot {
  background: #4caf50;
}

.connection-bar.disconnected .connection-dot {
  background: #ff9800;
}

.connection-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
}

.connection-action {
  font-size: 24rpx;
  color: #e03229;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-back:active {
  background-color: rgba(224, 50, 41, 0.1);
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 80rpx;
}

/* 加载状态 */
.loading {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-state text {
  margin-top: 24rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  color: #bbb !important;
}

/* 历史记录列表 */
.history-list {
  flex: 1;
  padding: 16rpx;
}

/* 历史卡片 */
.history-card {
  display: flex;
  justify-content: space-between;
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(224, 50, 41, 0.05);
}

.card-content {
  display: flex;
  justify-content: space-between;
  flex: 1;
  gap: 24rpx;
}

.card-info {
  flex: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 8rpx;
}

.card-score {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.score-number {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary);
}

.score-unit {
  font-size: 20rpx;
  color: rgba(224, 50, 41, 0.7);
}

.card-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid rgba(224, 50, 41, 0.1);
  flex-shrink: 0;
}

.card-image image {
  width: 100%;
  height: 100%;
}

/* 底部间距 */
.bottom-space {
  height: 120rpx;
}