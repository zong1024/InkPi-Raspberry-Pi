<!--pages/history/history.wxml-->
<view class="history-container">
  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="nav-back" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">历史记录</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 连接状态栏 -->
  <view class="connection-bar {{isConnected ? 'connected' : 'disconnected'}}" bindtap="goToIndex">
    <view class="connection-dot"></view>
    <text class="connection-text">{{connectionStatus}}</text>
    <text class="connection-action">{{isConnected ? '已连接' : '点击连接'}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{historyList.length === 0}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text>暂无评测记录</text>
    <text class="empty-hint">请使用树莓派设备进行书法评测</text>
  </view>

  <!-- 历史记录列表 -->
  <scroll-view wx:else class="history-list" scroll-y="true">
    <view 
      class="history-card" 
      wx:for="{{historyList}}" 
      wx:key="_id"
      bindtap="onViewDetail"
      data-id="{{item._id}}"
    >
      <view class="card-content">
        <view class="card-info">
          <text class="card-date">{{item.date}}</text>
          <text class="card-title">{{item.title}}</text>
          <view class="card-score">
            <text class="score-number">{{item.totalScore}}</text>
            <text class="score-unit">分</text>
            <view class="tag {{item.totalScore >= 80 ? 'tag-success' : ''}}">
              {{item.totalScore >= 80 ? '优秀' : item.totalScore >= 60 ? '良好' : '需努力'}}
            </view>
          </view>
        </view>
        <view class="card-image">
          <image src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
      </view>
      <view class="card-footer">
        <text class="view-detail">查看报告</text>
        <text class="arrow">→</text>
      </view>
    </view>
    
    <!-- 底部间距 -->
    <view class="bottom-space"></view>
  </scroll-view>
</view>