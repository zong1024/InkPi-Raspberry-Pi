/* pages/detail/detail.wxss */

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--background);
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--background);
  border-bottom: 1rpx solid rgba(224, 50, 41, 0.1);
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-back:active {
  background-color: rgba(224, 50, 41, 0.1);
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 80rpx;
}

/* 内容区域 */
.detail-content {
  flex: 1;
  padding: 24rpx;
}

/* 图片区域 */
.image-section {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.result-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 8rpx;
}

.result-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

/* 总分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.total-score {
  font-size: 120rpx;
  font-weight: bold;
  color: var(--primary);
  line-height: 1;
}

.score-max {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 四维评分 */
.dimension-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.dimension-item {
  margin-bottom: 24rpx;
}

.dimension-item:last-child {
  margin-bottom: 0;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dimension-name {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.dimension-score {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary);
}

.progress-bar {
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, var(--primary), var(--primary-light));
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 雷达图 */
.radar-section {
  margin-bottom: 24rpx;
}

.radar-canvas {
  width: 100%;
  height: 400rpx;
}

/* 反馈区域 */
.feedback-section {
  margin-bottom: 24rpx;
}

.feedback-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 识别结果 */
.recognition-section {
  margin-bottom: 24rpx;
}

.char-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.recognized-char {
  font-size: 120rpx;
  font-weight: bold;
  color: #333;
  line-height: 1;
  margin-bottom: 16rpx;
}

.confidence {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 底部间距 */
.bottom-space {
  height: 48rpx;
}