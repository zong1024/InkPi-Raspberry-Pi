      <text class="metric-note">й—Ғе“„зүғйҚӢж’»еј¶?7 жҝ ?{{summary.recentAverageText}}</text>
    </view>
    <view class="paper-panel metric-card">
      <text class="metric-label">жҝһжқ‘еҗӢйЎӯеӣ¬пҪһйҚӣеӯҳеҒқ</text>
