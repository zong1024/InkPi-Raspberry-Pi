        <text class="growth-metric-value">{{item.value}}</text>
        <text class="growth-metric-note">{{item.note}}</text>
      </view>
    </view>

    <view class="chip-row">
      <text class="meta-chip">{{growthSummary.lastPracticeText}}</text>
