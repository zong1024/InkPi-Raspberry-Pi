      <text class="meta-chip">жҝһжҲһжЈ‘зјӮж°ұзҙһ?{{activeScriptLabel}}</text>
      <text class="meta-chip">{{methodology.validation.statusLabel}}</text>
    </view>
  </view>

  <view class="paper-panel filter-panel">
    <view class="section-head">
      <text class="section-title">зјӮеӮҷиғ¶йҚ жӣўо”ҳйҺјдҪ№еҡ‘й–ёж„©еҠҚз»ҫ</text>
      <text class="section-note">й—ҒеңӯоҹҲйЎҰжқҝоңғйҚҢзӮҙв’’жҝһпҪҺе…ҳйҚӢж’ҙжӢ…е®„жқҝоқ жҝһиҫҫзөҫйҺёжҗҒе№ҸйҺөоҶҪеӘјй–№оҲҶеұҫРЈй—Ғе‘Ҡеё’еЁІп№Җз•·йҸҢгғҘзӨҶй–ёв„ғоҹҮйҲ§оғҝзІҷе®•пҪүж•җйҚӣоҲңзҚ®</text>
    </view>
    <view class="picker-grid">
      <picker mode="selector" range="{{dateOptions}}" value="{{filters.dateIndex}}" bindchange="onDateChange">
