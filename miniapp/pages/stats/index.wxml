<view class="page-shell stats-page">
  <view class="page-orb page-orb-a"></view>
  <view class="page-orb page-orb-b"></view>

  <view class="paper-panel stats-hero">
    <view class="section-head">
      <view>
        <text class="eyebrow">InkPi Analytics</text>
        <text class="stats-title">统计中心</text>
      </view>
      <button class="ghost-btn back-btn" bindtap="goHistory">返回记录</button>
    </view>
    <text class="stats-subtitle">
      这里同时展示学习统计、样本量化、评价依据和验证计划，方便把“能跑”升级为“能解释、能量化、能持续优化”。
    </text>
    <view class="chip-row">
      <text class="meta-chip">最近刷新 {{lastUpdated || '尚未同步'}}</text>
      <text class="meta-chip">统计样本 {{summary.total}}</text>
      <text class="meta-chip">{{methodology.validation.statusLabel}}</text>
    </view>
  </view>

  <view class="paper-panel filter-panel">
    <view class="section-head">
      <text class="section-title">统计范围</text>
      <text class="section-note">按设备和时间切换分析口径</text>
    </view>
    <view class="picker-grid">
      <picker mode="selector" range="{{dateOptions}}" value="{{filters.dateIndex}}" bindchange="onDateChange">
        <view class="picker-chip">时间：{{dateOptions[filters.dateIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{deviceOptions}}" value="{{filters.deviceIndex}}" bindchange="onDeviceChange">
        <view class="picker-chip">设备：{{deviceOptions[filters.deviceIndex]}}</view>
      </picker>
    </view>
  </view>

  <view wx:if="{{error}}" class="notice notice-error">{{error}}</view>
  <view wx:if="{{loading}}" class="notice">正在生成统计结果...</view>

  <view class="stats-grid">
    <view class="paper-panel metric-card">
      <text class="metric-label">平均分</text>
      <text class="metric-value">{{summary.averageText}}</text>
      <text class="metric-note">最近 7 天 {{summary.recentAverageText}}</text>
    </view>
    <view class="paper-panel metric-card">
      <text class="metric-label">优秀率</text>
      <text class="metric-value">{{summary.excellentRateText}}</text>
      <text class="metric-note">达标率 {{summary.qualifiedRateText}}</text>
    </view>
    <view class="paper-panel metric-card">
      <text class="metric-label">最近变化</text>
      <text class="metric-value">{{summary.progressText}}</text>
      <text class="metric-note">{{summary.progressLabel}}</text>
    </view>
    <view class="paper-panel metric-card">
      <text class="metric-label">最高分</text>
      <text class="metric-value">{{summary.bestScoreText}}</text>
      <text class="metric-note">累计样本 {{summary.total}}</text>
    </view>
  </view>

  <view class="paper-panel evidence-panel">
    <view class="section-head">
      <text class="section-title">量化证据</text>
      <text class="section-note">直接回应样本量、覆盖面和验证进度</text>
    </view>

    <view class="evidence-grid">
      <view class="evidence-card">
        <text class="evidence-label">当前样本</text>
        <text class="evidence-value">{{methodology.validation.currentSampleCount}}</text>
      </view>
      <view class="evidence-card">
        <text class="evidence-label">覆盖汉字</text>
        <text class="evidence-value">{{methodology.validation.uniqueCharacters}}</text>
      </view>
      <view class="evidence-card">
        <text class="evidence-label">设备来源</text>
        <text class="evidence-value">{{methodology.validation.deviceCount}}</text>
      </view>
      <view class="evidence-card">
        <text class="evidence-label">目标进度</text>
        <text class="evidence-value">{{methodology.validation.coverageRatioText}}</text>
      </view>
    </view>

    <view class="target-row">
      <text class="meta-chip">标注目标 {{methodology.validation.labelTarget}}</text>
      <text class="meta-chip">教师校核 {{methodology.validation.expertReviewTarget}}</text>
      <text class="meta-chip">试用用户 {{methodology.validation.trialUserTarget}}</text>
    </view>
  </view>

  <view class="panel-duo">
    <view class="paper-panel roadmap-panel">
      <view class="section-head">
        <text class="section-title">验证计划</text>
        <text class="section-note">{{methodology.validation.currentStage}}</text>
      </view>
      <text class="roadmap-copy">{{methodology.validation.nextMilestone}}</text>
      <view class="policy-list">
        <view wx:for="{{methodology.validation.reviewPolicy}}" wx:key="*this" class="policy-item">
          <text class="policy-dot"></text>
          <text class="policy-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="paper-panel roadmap-panel">
      <view class="section-head">
        <text class="section-title">项目边界</text>
        <text class="section-note">先把定位说清楚</text>
      </view>
      <text class="roadmap-copy">{{methodology.framework.projectPosition}}</text>
      <text class="roadmap-note">{{methodology.framework.currentScope}}</text>
      <text class="roadmap-note">{{methodology.framework.boundaryNote}}</text>
      <view class="target-row">
        <text wx:for="{{methodology.framework.currentScripts}}" wx:key="*this" class="meta-chip">当前 {{item}}</text>
        <text wx:for="{{methodology.framework.roadmapScripts}}" wx:key="*this" class="meta-chip">规划 {{item}}</text>
      </view>
    </view>
  </view>

  <view class="paper-panel chart-panel">
    <view class="section-head">
      <text class="section-title">最近 10 天趋势</text>
      <text class="section-note">柱高表示平均分，顶部数字表示样本数</text>
    </view>
    <view class="trend-chart">
      <view wx:for="{{summary.trendPoints}}" wx:key="date" class="trend-item">
        <text class="trend-count">{{item.count}}</text>
        <view class="trend-bar-shell">
          <view class="trend-bar" style="height: {{item.barHeight}}%;"></view>
        </view>
        <text class="trend-avg">{{item.averageText}}</text>
        <text class="trend-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="paper-panel chart-panel">
    <view class="section-head">
      <text class="section-title">分数分布</text>
      <text class="section-note">快速看当前成绩集中在哪个区间</text>
    </view>
    <view wx:for="{{summary.scoreBands}}" wx:key="key" class="distribution-row">
      <view class="distribution-top">
        <text class="distribution-label">{{item.label}}</text>
        <text class="distribution-value">{{item.count}} / {{item.ratioText}}</text>
      </view>
      <view class="distribution-track">
        <view class="distribution-fill" style="width: {{item.width}}%;"></view>
      </view>
    </view>
  </view>

  <view class="paper-panel chart-panel">
    <view class="section-head">
      <text class="section-title">四维均值</text>
      <text class="section-note">用于观察整体训练趋势，而不是替代老师定级</text>
    </view>
    <view wx:for="{{summary.dimensions}}" wx:key="key" class="distribution-row">
      <view class="distribution-top">
        <text class="distribution-label">{{item.label}}</text>
        <text class="distribution-value">{{item.score}}</text>
      </view>
      <view class="distribution-track">
        <view class="distribution-fill dimension-fill" style="width: {{item.width}}%;"></view>
      </view>
    </view>
  </view>

  <view class="leaderboard-grid">
    <view class="paper-panel leaderboard-panel">
      <view class="section-head">
        <text class="section-title">高频练习字</text>
        <text class="section-note">按出现次数排序</text>
      </view>
      <view wx:if="{{summary.topCharacters.length}}">
        <view wx:for="{{summary.topCharacters}}" wx:key="character_name" class="leaderboard-row">
          <view>
            <text class="leaderboard-main">{{item.character_name}}</text>
            <text class="leaderboard-sub">{{item.count}} 次</text>
          </view>
          <text class="leaderboard-score">{{item.average_score}}</text>
        </view>
      </view>
      <text wx:else class="panel-subtitle">当前还没有足够的数据生成排行。</text>
    </view>

    <view class="paper-panel leaderboard-panel">
      <view class="section-head">
        <text class="section-title">设备来源</text>
        <text class="section-note">按样本量排序</text>
      </view>
      <view wx:if="{{summary.topDevices.length}}">
        <view wx:for="{{summary.topDevices}}" wx:key="device_name" class="leaderboard-row">
          <view>
            <text class="leaderboard-main">{{item.device_name}}</text>
            <text class="leaderboard-sub">{{item.count}} 条</text>
          </view>
          <text class="leaderboard-score">{{item.average_score}}</text>
        </view>
      </view>
      <text wx:else class="panel-subtitle">当前还没有设备侧上传数据。</text>
    </view>
  </view>

  <view class="paper-panel reference-panel">
    <view class="section-head">
      <text class="section-title">评价依据来源</text>
      <text class="section-note">把“为什么这样评”讲清楚</text>
    </view>
    <view wx:for="{{methodology.references}}" wx:key="title" class="reference-card">
      <view class="reference-top">
        <text class="reference-title">{{item.title}}</text>
        <text class="reference-tag">{{item.tag}}</text>
      </view>
      <text class="reference-role">{{item.role}}</text>
    </view>
  </view>

  <view class="paper-panel insight-panel">
    <text class="panel-title">自动总结</text>
    <text class="insight-copy">{{summary.insight}}</text>
  </view>
</view>
