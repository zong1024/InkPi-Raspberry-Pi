      <text class="meta-chip">{{supportScopeText}}</text>
    </view>

    <view wx:if="{{focusDimension}}" class="growth-focus-card">
      <text class="growth-focus-title">йҗҹж»…еў—йҺёе‘Ҡжҷ¶йҗҳеҶІоҮұжҝЎоҲҡжҗ«з”Ҝгғ©жӮ¶еЁ‘ж §еҠҡзҖ№жҗҒдә¶йҸҒе¶…оқўз»әз§„ocusDimension.label}}</text>
      <text class="growth-focus-copy">{{focusDimension.note}}</text>
    </view>

    <view class="policy-list growth-steps">
      <view wx:for="{{practiceSteps}}" wx:key="*this" class="policy-item">
        <text class="policy-dot"></text>
        <text class="policy-text">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{practicePreview.length}}" class="growth-preview-grid">
      <view wx:for="{{practicePreview}}" wx:key="character" class="growth-preview-card">
        <view class="growth-preview-top">
          <text class="growth-preview-char">{{item.character}}</text>
          <text class="growth-preview-badge">{{item.badgeText}}</text>
        </view>
        <text class="growth-preview-meta">й—Ғз§ҶеҶ©жҗҗй–ё?{{item.averageText}} / й—Ғе“„зүғйҚӢж’»еј¶?{{item.latestScoreText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{error}}" class="notice notice-error">{{error}}</view>
  <view wx:if="{{loading}}" class="notice">е©өоҶҪз№җз»Іи—үп№ўйЎҸе ҹеҒЁй–»ж—ӮоҹҲйҗҸеӣ©зҙ“жөЈе“„жһҷжӨӨж’іж‘ңз»ұжҺ—е№ҳзҖөй•җеҮҪ...</view>

  <view class="stats-grid">
