        <view class="picker-chip">й–»зҠұз„ҰйҚҺжҠҪЛҮйЎ’еӢ¬жҷ¬жҝ®жҝҲд»ҳdeviceOptions[filters.deviceIndex]}}</view>
      </picker>
    </view>
  </view>

  <view class="paper-panel growth-panel">
    <view class="section-head">
      <text class="section-title">й—Ғдјҷзөҫйҗҹгғ©жӮәйҠҠпёҫв–”йҺјж·¬еһ№йҗҸеӣ¬жў»йҲ§</text>
      <button class="ghost-btn practice-btn" bindtap="goPractice">зјӮеӮҷзӨҒйҚҹв•ғеј§йҚ•о„Ӯв–”жӨӨж’¶еҒҹжҝЎ</button>
