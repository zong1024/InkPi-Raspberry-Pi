      </picker>
      <picker mode="selector" range="{{scriptOptions}}" value="{{filters.scriptIndex}}" bindchange="onScriptChange">
        <view class="picker-chip">жҝһжҲһжЈ‘зјӮж°ұзҙһзҖЈоҶҪжҷ¬жҝ®жҝҲд»ҳscriptOptions[filters.scriptIndex]}}</view>
      </picker>
