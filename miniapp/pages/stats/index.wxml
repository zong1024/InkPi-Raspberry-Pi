      </view>
      <text wx:else class="panel-subtitle">йҗҹж»…еў—йҺёе‘Ҡжҷ¶йҗҳиҷ«дәӨжҝЎоҲқеҙөе§Ҡй№ғжҹЎйҚ«жҝҗж§јй–ёж„®зІҜеҜ°еӢҜжӮўйҗ‘жЁјжҡ й—ҒиҪ°иғ¶жҫ§жҘҖз•өжёҡвӮ¬йҺ®д»ӢжӮўз»Ӣи·ЁдәЈй—Ғеңӯе„Өз”ҜзҶјгҖҒйҺҙп№ҖОҘ</text>
    </view>

    <view class="paper-panel leaderboard-panel">
      <view class="section-head">
        <text class="section-title">й–»зҠұз„ҰйҚҺжҠҪЛҮйЎ’еӢ«зә§й–өеӨӣеҰҮйҗ–</text>
        <text class="section-note">й—ҒеңӯоҹҲйЎҰдјҙжӮ§й–¬е¶…е«үжӨӨжҺ‘е«¬еЁ…гӮүжҹҹйҗ‘жЁәз¬’зјҒ</text>
      </view>
      <view wx:if="{{summary.topDevices.length}}">
        <view wx:for="{{summary.topDevices}}" wx:key="device_name" class="leaderboard-row">
          <view>
            <text class="leaderboard-main">{{item.device_name}}</text>
            <text class="leaderboard-sub">{{item.count}} й—Ғ</text>
          </view>
          <text class="leaderboard-score">{{item.average_score}}</text>
        </view>
      </view>
      <text wx:else class="panel-subtitle">йҗҹж»…еў—йҺёе‘Ҡжҷ¶йҗҳиҷ«дәӨжҝЎоҲқеҙөе§Ҡй№ғжҹЎйҚ«жҝҗж§јжӨӨж—ҖжҙҳеҜ°еӢҜеҙ¶й””иҠҘзҸ·жҝһжҲһжҢёй”•пҪҮж§җйҚ«жӣһжһҒй–»жҘҖзүҶз»Ғп№Ӯжҹ•</text>
    </view>
  </view>

  <view class="paper-panel reference-panel">
    <view class="section-head">
      <text class="section-title">й–»зҠІжҙӨзҖҡоҒҲжӮійЎ–ж¶ҡз‘№жҝ йқӣжҙӨз»Ғп№ӮжҹЎжҫ¶е қеҠңзјҒ</text>
      <text class="section-note">й—ҒзЎ…жіӣиүҢй–іСҢеүҡз»®е ўжӢ№йҗ”е“Ҙоӣ·й–іСҢеүҡз»Ӣе©Үеҙјй”қеӣ©оҶҗй—Ғе“„з§¶йҸҢеӨҗжғҒжҗҙг„ҘзҒіжҝ йқӣоҹ¬йҚһи§„з№ӣйҺҫиҷ«еҷәжӨӨ</text>
    </view>
    <view wx:for="{{methodology.references}}" wx:key="title" class="reference-card">
      <view class="reference-top">
        <text class="reference-title">{{item.title}}</text>
        <text class="reference-tag">{{item.tag}}</text>
