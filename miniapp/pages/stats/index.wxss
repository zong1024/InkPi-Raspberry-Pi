.stats-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stats-hero,
.filter-panel,
.growth-panel,
.chart-panel,
.leaderboard-panel,
.insight-panel,
.evidence-panel,
.roadmap-panel,
.reference-panel {
  padding: 28rpx 26rpx;
}

.stats-title {
  display: block;
  margin-top: 16rpx;
  font-size: 54rpx;
  line-height: 1.04;
  font-weight: 800;
  color: #2e2219;
}

.stats-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #75624e;
}

.back-btn {
  margin: 0;
  min-width: 170rpx;
  padding: 0 24rpx;
}

.practice-btn {
  margin: 0;
  min-width: 190rpx;
}

.picker-grid,
.stats-grid,
.evidence-grid,
.growth-grid,
.leaderboard-grid,
.panel-duo {
  display: grid;
  gap: 14rpx;
}

.picker-grid {
  margin-top: 18rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.picker-chip {
  min-height: 78rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: rgba(248, 240, 228, 0.98);
  border: 1rpx solid rgba(191, 169, 144, 0.56);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  color: #6d5541;
  font-size: 24rpx;
  font-weight: 600;
}

.stats-grid,
.evidence-grid,
.growth-grid,
.leaderboard-grid,
.panel-duo {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-card {
  padding: 24rpx 20rpx;
}

.metric-label,
.evidence-label {
  display: block;
  font-size: 22rpx;
  color: #8a7560;
}

.metric-value,
.evidence-value {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #31261c;
}

.metric-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d6651;
}

.growth-copy,
.growth-focus-copy,
.growth-preview-meta {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d6651;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f241a;
}

.section-note {
  font-size: 22rpx;
  color: #8a7560;
}

.target-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.evidence-card,
.growth-metric-card,
.reference-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.growth-metric-label {
  display: block;
  font-size: 22rpx;
  color: #8a7560;
}

.growth-metric-value {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
  color: #31261c;
}

.growth-metric-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d6651;
}

.growth-focus-card,
.growth-preview-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.growth-focus-title,
.growth-preview-char {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.growth-steps {
  margin-top: 18rpx;
}

.growth-preview-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.growth-preview-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.growth-preview-badge {
  font-size: 22rpx;
  color: #8a7560;
}

.roadmap-copy,
.roadmap-note,
.reference-role,
.insight-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #4f4031;
}

.policy-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.policy-item {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.policy-dot {
  margin-top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #b11828;
}

.policy-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4f4031;
}

.trend-chart {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14rpx;
}

.trend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.trend-count,
.trend-avg,
.trend-label {
  font-size: 20rpx;
  color: #7d6651;
}

.trend-count {
  font-weight: 700;
  color: #533f31;
}

.trend-bar-shell {
  width: 100%;
  height: 160rpx;
  border-radius: 999rpx;
  background: rgba(230, 218, 204, 0.72);
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.trend-bar {
  width: 100%;
  border-radius: inherit;
  background: linear-gradient(180deg, #c66f3f 0%, #8d5533 100%);
}

.distribution-row {
  margin-top: 20rpx;
}

.distribution-top,
.reference-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.distribution-label,
.leaderboard-main,
.reference-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #3f3125;
}

.distribution-value,
.leaderboard-sub,
.reference-tag {
  font-size: 22rpx;
  color: #7d6651;
}

.distribution-track {
  margin-top: 12rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(190, 169, 144, 0.28);
  overflow: hidden;
}

.distribution-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ba7440 0%, #8d5533 100%);
}

.dimension-fill {
  background: linear-gradient(90deg, #b11828 0%, #7f1021 100%);
}

.leaderboard-row {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.leaderboard-score {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 800;
  color: #6c4e36;
}

@media (max-width: 520px) {
  .leaderboard-grid,
  .stats-grid,
  .growth-grid,
  .picker-grid,
  .evidence-grid,
  .panel-duo,
  .growth-preview-grid {
    grid-template-columns: 1fr;
  }
}
