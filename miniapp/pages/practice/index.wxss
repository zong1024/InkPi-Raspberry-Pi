.practice-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.practice-hero,
.goal-panel,
.focus-panel,
.plan-panel,
.recommend-panel,
.summary-panel,
.milestone-card {
  padding: 28rpx 26rpx;
}

.practice-title {
  display: block;
  margin-top: 16rpx;
  font-size: 54rpx;
  line-height: 1.04;
  font-weight: 800;
  color: #2e2219;
}

.practice-subtitle,
.practice-source,
.goal-copy,
.plan-subtitle,
.plan-footer,
.recommend-reason,
.recommend-meta,
.focus-gap {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #75624e;
}

.practice-source {
  margin-top: 14rpx;
  color: #8f5730;
}

.hero-back {
  margin: 0;
  min-width: 170rpx;
}

.goal-shell,
.milestone-grid,
.focus-grid,
.summary-grid {
  display: grid;
  gap: 14rpx;
}

.milestone-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.focus-grid,
.summary-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.goal-track {
  margin-top: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(207, 185, 160, 0.32);
  overflow: hidden;
}

.goal-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #b11828 0%, #c66f3f 100%);
}

.goal-meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.goal-meta-item,
.recommend-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(239, 227, 212, 0.9);
  color: #7a5a41;
  font-size: 22rpx;
}

.milestone-card {
  min-height: 164rpx;
}

.milestone-label,
.summary-label {
  display: block;
  font-size: 22rpx;
  color: #8a7560;
}

.milestone-value,
.summary-value,
.focus-score {
  display: block;
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 800;
  color: #31261c;
}

.milestone-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d6651;
}

.focus-panel-main {
  background: rgba(255, 247, 242, 0.98);
  border-color: rgba(188, 112, 71, 0.28);
}

.focus-score-row,
.recommend-top {
  margin-top: 18rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
}

.focus-name,
.recommend-character {
  font-size: 30rpx;
  font-weight: 700;
  color: #3f3125;
}

.plan-list,
.recommend-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plan-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.plan-dot {
  margin-top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #b11828;
}

.plan-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4f4031;
}

.recommend-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.recommend-average {
  font-size: 24rpx;
  font-weight: 700;
  color: #6c4e36;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  margin: 0;
}

@media (max-width: 520px) {
  .milestone-grid,
  .focus-grid,
  .summary-grid {
    grid-template-columns: 1fr;
  }
}
