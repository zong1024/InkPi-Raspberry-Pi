.result-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-hero,
.metrics-panel,
.dimensions-panel,
.feedback-panel {
  padding: 30rpx 28rpx;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.detail-copy {
  flex: 1;
}

.detail-character-wrap {
  margin-top: 18rpx;
  width: 1.4em;
  min-height: 1.24em;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-character {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 70rpx;
  line-height: 1.08;
  font-weight: 800;
  color: #2d2219;
}

.detail-meta {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7e6955;
}

.score-plaque {
  width: 178rpx;
  min-height: 178rpx;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-plaque-value {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 800;
}

.score-plaque-unit {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-foot {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-grade {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.metric-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.metric-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.metric-value {
  font-size: 24rpx;
  color: #7d6651;
  font-weight: 700;
}

.metric-note {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7d6651;
}

.dimension-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.dimension-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.dimension-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.dimension-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.dimension-score {
  font-size: 34rpx;
  font-weight: 800;
  color: #6c4e36;
}

.dimension-track {
  margin-top: 16rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(190, 169, 144, 0.38);
  overflow: hidden;
}

.dimension-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ba7440 0%, #8d5533 100%);
}

.feedback-quote {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.9;
  color: #4f4032;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.detail-back,
.detail-delete {
  flex: 1;
  margin: 0;
}

.detail-delete {
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(252, 227, 221, 0.96);
  color: #b34b3e;
  border: 1rpx solid rgba(214, 124, 102, 0.42);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}

@media (max-width: 520px) {
  .dimension-grid {
    grid-template-columns: 1fr;
  }
}
