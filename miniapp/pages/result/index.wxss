.result-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-hero,
.metrics-panel,
.feedback-panel {
  padding: 30rpx 28rpx;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.detail-copy {
  flex: 1;
}

.detail-character {
  display: block;
  margin-top: 18rpx;
  font-size: 70rpx;
  line-height: 1.02;
  font-weight: 800;
  color: #2d2219;
}

.detail-meta {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7e6955;
}

.score-plaque {
  width: 178rpx;
  min-height: 178rpx;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-plaque-value {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 800;
}

.score-plaque-unit {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-foot {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-grade {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.metric-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.metric-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.metric-value {
  font-size: 24rpx;
  color: #7d6651;
  font-weight: 700;
}

.metric-note {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7d6651;
}

.feedback-quote {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.9;
  color: #4f4032;
}
