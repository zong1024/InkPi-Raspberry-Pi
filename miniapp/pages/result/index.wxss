.result-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-hero,
.metrics-panel,
.dimensions-panel,
.basis-panel,
.practice-panel,
.follow-panel,
.feedback-panel {
  padding: 30rpx 28rpx;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.detail-copy {
  flex: 1;
}

.detail-character {
  display: block;
  margin-top: 18rpx;
  font-size: 70rpx;
  line-height: 1.02;
  font-weight: 800;
  color: #2d2219;
}

.detail-meta {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7e6955;
}

.detail-support {
  display: block;
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #8a6450;
}

.score-plaque {
  width: 178rpx;
  min-height: 178rpx;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-plaque-value {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 800;
}

.score-plaque-unit {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-foot {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-grade {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-card,
.basis-card,
.practice-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.metric-top,
.dimension-top,
.basis-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.metric-name,
.dimension-label,
.basis-name,
.practice-card-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.metric-value,
.basis-score {
  font-size: 24rpx;
  color: #7d6651;
  font-weight: 700;
}

.metric-note,
.basis-question,
.basis-feature,
.basis-tip,
.practice-card-note {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7d6651;
}

.dimension-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.dimension-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.dimension-score,
.practice-card-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #6c4e36;
}

.dimension-track {
  margin-top: 16rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(190, 169, 144, 0.38);
  overflow: hidden;
}

.dimension-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ba7440 0%, #8d5533 100%);
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.basis-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(247, 238, 225, 0.96);
  color: #6f563f;
  font-size: 22rpx;
}

.practice-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #4f4032;
}

.practice-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.practice-card-good {
  background: rgba(233, 244, 235, 0.96);
  border-color: rgba(113, 158, 122, 0.38);
}

.practice-card-focus {
  background: rgba(252, 240, 228, 0.96);
  border-color: rgba(186, 116, 64, 0.3);
}

.action-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.action-dot {
  margin-top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #b11828;
}

.action-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4f4032;
}

.feedback-quote {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.9;
  color: #4f4032;
}

.follow-chip-row {
  margin-top: 18rpx;
}

.follow-preview-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.follow-preview-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(252, 247, 239, 0.92);
  border: 1rpx solid rgba(214, 193, 167, 0.72);
}

.follow-preview-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.follow-preview-char {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f3125;
}

.follow-preview-badge,
.follow-preview-meta {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d6651;
}

.follow-preview-meta {
  display: block;
  margin-top: 12rpx;
}

.follow-cta {
  margin-top: 22rpx;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.detail-back,
.detail-stats,
.detail-delete {
  flex: 1;
  margin: 0;
}

.detail-delete {
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(252, 227, 221, 0.96);
  color: #b34b3e;
  border: 1rpx solid rgba(214, 124, 102, 0.42);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.detail-warning {
  background: rgba(252, 227, 221, 0.96);
  color: #b34b3e;
}

@media (max-width: 520px) {
  .dimension-grid,
  .practice-grid,
  .follow-preview-grid {
    grid-template-columns: 1fr;
  }
}
