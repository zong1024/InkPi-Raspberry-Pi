.history-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero-sheet {
  padding: 32rpx 28rpx 26rpx;
}

.hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 56rpx;
  line-height: 1.04;
  font-weight: 800;
  color: #2e2219;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #75624e;
}

.logout-btn {
  margin: 0;
  padding: 0 24rpx;
  min-width: 140rpx;
}

.hero-meta {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-seal {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(239, 227, 212, 0.95);
  color: #7c583d;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-strip {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 14rpx;
}

.summary-item {
  flex: 1;
  min-height: 132rpx;
  padding: 22rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 243, 0.82);
  border: 1rpx solid rgba(191, 169, 144, 0.56);
  box-sizing: border-box;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #8a7560;
}

.summary-value {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #31261c;
}

.section-head {
  position: relative;
  z-index: 1;
  padding: 10rpx 4rpx 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f241a;
}

.section-note {
  font-size: 22rpx;
  color: #8a7560;
}

.record-sheet {
  padding: 24rpx 22rpx;
  display: flex;
  gap: 18rpx;
}

.record-stamp {
  width: 146rpx;
  min-height: 172rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.record-char {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.record-style {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.record-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-score-line {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.record-score {
  font-size: 56rpx;
  line-height: 1;
  font-weight: 800;
}

.record-grade {
  font-size: 24rpx;
  color: #7a6550;
  font-weight: 700;
}

.record-time {
  font-size: 23rpx;
  line-height: 1.6;
  color: #8a745f;
}

.record-feedback {
  font-size: 25rpx;
  line-height: 1.68;
  color: #4f4031;
}

.record-dimensions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dimension-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(242, 234, 223, 0.95);
  color: #6d5541;
  font-size: 22rpx;
}
