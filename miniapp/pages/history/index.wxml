      </view>
    </view>
  </view>

  <view class="summary-grid">
    <view class="summary-item">
      <text class="summary-label">閺夆晝鍋熼悽鑽ょ磼閸愌呯槑</text>
      <text class="summary-value">{{growthSummary.streakText}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">闁哄牜鍓欓幊鍡涙儎椤旂晫鍨</text>
      <text class="summary-value">{{growthSummary.weekGoalText}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">閺?7 濠㈠灈鏅涘搴ㄥ礆</text>
      <text class="summary-value">{{summary.recentAverageText}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">缂侀硸鍨甸鍝ユ媼閺夎法绉</text>
      <text class="summary-value">{{summary.total}}</text>
    </view>
  </view>

  <view class="paper-panel growth-panel">
    <view class="section-head">
      <text class="section-title">闁瑰瓨鍔欓弳杈╂媼閳ュ啿鐏</text>
      <button class="ghost-btn practice-btn" bindtap="goPractice">闁告顕ч悾銊╁箳閹哄秶鐟撳☉鎾亾閺</button>
    </view>
    <text class="growth-copy">{{growthSummary.message}}</text>

    <view class="goal-track">
      <view class="goal-fill" style="width: {{growthSummary.weekGoalPercent}}%;"></view>
    </view>

    <view class="growth-chips">
      <text class="meta-chip">{{growthSummary.lastPracticeText}}</text>
      <text class="meta-chip">闁哄牜鍓欓幊鍡樼▔婵犱胶鐐?{{growthSummary.weekRecords}} 闁</text>
      <text class="meta-chip">缂佸鍟块悾?80+ {{growthSummary.stableProgressText}}</text>
    </view>

    <view wx:if="{{focusDimension}}" class="growth-focus-card">
      <text class="growth-focus-title">鐟滅増鎸告晶鐘冲濡搫甯ラ悶娑栧劚瀹搁亶鏁嶅绺秄ocusDimension.label}}</text>
      <text class="growth-focus-copy">{{focusDimension.note}}</text>
    </view>

    <view class="growth-step-list">
      <view wx:for="{{practiceSteps}}" wx:key="*this" class="growth-step-item">
        <text class="growth-step-dot"></text>
        <text class="growth-step-text">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{practicePreview.length}}" class="practice-preview-grid">
      <view wx:for="{{practicePreview}}" wx:key="character" class="practice-preview-card">
        <view class="practice-preview-top">
          <text class="practice-preview-char">{{item.character}}</text>
          <text class="practice-preview-badge">{{item.badgeText}}</text>
        </view>
        <text class="practice-preview-meta">闁秆冩搐閸?{{item.averageText}} / 闁哄牃鍋撻弶?{{item.latestScoreText}}</text>
      </view>
    </view>
  </view>

  <view class="paper-panel digest-panel">
    <view class="section-head">
      <text class="section-title">闂佹彃绻愮€垫彃顫楅崒婵愭綌</text>
      <text class="section-note">{{summary.topDeviceText}}</text>
    </view>

    <view class="quality-strip">
      <view class="quality-pill quality-good">
        <text class="quality-name">濞</text>
        <text class="quality-count">{{summary.qualityCounts.good}}</text>
      </view>
      <view class="quality-pill quality-medium">
