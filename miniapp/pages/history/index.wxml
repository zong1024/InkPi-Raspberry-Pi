        <text class="quality-count">{{summary.qualityCounts.medium}}</text>
      </view>
      <view class="quality-pill quality-bad">
        <text class="quality-name">鐎垫澘鎳忚ぐ渚€宕</text>
        <text class="quality-count">{{summary.qualityCounts.bad}}</text>
      </view>
    </view>

    <view class="metrics-duo">
      <view class="metric-chip">
        <text class="metric-chip-label">閺夊牏鍋撻悥锝夋偝</text>
        <text class="metric-chip-value">{{summary.qualifiedRateText}}</text>
      </view>
      <view class="metric-chip">
        <text class="metric-chip-label">濞村吋顭囬～鍛存偝</text>
        <text class="metric-chip-value">{{summary.excellentRateText}}</text>
      </view>
    </view>

    <text class="digest-copy">{{summary.progressLabel}}</text>

    <view class="digest-tags">
      <text class="meta-chip">闁哄牃鍋撻柡鍌涙緲缁堕亶宕?{{summary.latestScoreText}}</text>
      <text class="meta-chip">濡ゅ倹锕㈤。鍓佲偓?{{summary.topCharacterText}}</text>
      <text class="meta-chip">閺?7 濠㈠灈鏅滈悧閬嶅嫉?{{summary.recentTotal}}</text>
      <text class="meta-chip">{{supportScopeShort}}</text>
    </view>

    <text class="digest-note">{{summary.insight}}</text>
  </view>

  <view class="paper-panel filter-panel">
    <view class="section-head">
      <text class="section-title">缂佹稒鐩埀顒€顦粭宀勫极鐎靛憡鍊</text>
      <text class="section-note">{{hasActiveFilters ? '鐟滅増鎸告晶鐘差啅閹绘帗鍎欓柣顫妿閻☆偊鏌? : supportScopeShort}}</text>
    </view>

    <view class="search-row">
      <input
        class="search-input"
        placeholder="闁瑰吋绮庨崒銊バф径濠勬憻闁靛棔娴囬惁搴ｆ嫚椤撶喎鐏楅悹浣瑰劤椤?
        value="{{filters.keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="applyKeywordFilter"
        confirm-type="search"
      />
      <button class="secondary-btn search-btn" bindtap="applyKeywordFilter">闁瑰吋绮庨崒</button>
    </view>

    <view class="picker-grid">
      <picker mode="selector" range="{{qualityOptions}}" value="{{filters.qualityIndex}}" bindchange="onQualityChange">
        <view class="picker-chip">缂佹稑顦辨鍥晬濮濈付qualityOptions[filters.qualityIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{scriptOptions}}" value="{{filters.scriptIndex}}" bindchange="onScriptChange">
        <view class="picker-chip">濞戞棑缂氱紞瀣晬濮濈付scriptOptions[filters.scriptIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{dateOptions}}" value="{{filters.dateIndex}}" bindchange="onDateChange">
        <view class="picker-chip">闁哄啫鐖煎Λ鍧楁晬濮濈付dateOptions[filters.dateIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{sortOptions}}" value="{{filters.sortIndex}}" bindchange="onSortChange">
        <view class="picker-chip">闁圭儤甯掔花顓㈡晬濮濈付sortOptions[filters.sortIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{deviceOptions}}" value="{{filters.deviceIndex}}" bindchange="onDeviceChange">
        <view class="picker-chip">閻犱焦鍎抽ˇ顒勬晬濮濈付deviceOptions[filters.deviceIndex]}}</view>
      </picker>
    </view>

    <view class="filter-actions">
      <view class="filter-action-group">
        <button wx:if="{{hasActiveFilters}}" class="ghost-btn clear-btn" bindtap="clearFilters">婵炴挸鎳愰埞鏍驳濞戔懇鍋</button>
        <button class="ghost-btn manage-btn" bindtap="toggleManageMode">{{managing ? '闂侇偀鍋撻柛鎴ｆ椤撴悂鎮? : '闁归潧缍婇崳铏圭不閿涘嫭鍊?}}</button>
      </view>
      <text class="filter-hint">婵繐绲界槐锟犲绩椤栨稑鐦俊銈堟腹閸旂喐绋夋惔銈庢斀濞戞棑璁ｇ槐閬嶅礂閺堢數閾傚☉鏃撶細缂嶅宕￠崗鍛枏闁哄牆顦伴弳鐔煎箲椤旇崵鐦嶅ù鐘叉噸缂嶆梻浠﹂弴鐘粵闁挎稑濂旂粭澶岀棯閸愭彃寮虫慨婵撶到缁憋繝寮ㄩ娑樼槷闁肩厧鍟ú鍧楀Υ</text>
    </view>

    <view wx:if="{{managing}}" class="batch-toolbar">
      <text class="batch-label">鐎瑰憡鐓￠埀顒€顦扮€?{{selectedIds.length}} 闁</text>
      <view class="batch-actions">
        <button class="ghost-btn batch-chip" bindtap="selectAllRecords">闁稿繈鍔戦埀</button>
        <button class="ghost-btn batch-chip" bindtap="clearSelection">婵炴挸鎳愰埞</button>
        <button class="batch-delete" bindtap="batchDeleteSelected" loading="{{batchDeleting}}">
          闁归潧缍婇崳娲礆閻樼粯鐝?        </button>
      </view>
    </view>
  </view>

  <view class="section-head section-head-standalone">
    <text class="section-title">闁告ê妫楄ぐ鍓佹媼閺夎法绉</text>
    <text class="section-note">闁绘劗鎳撶槐鎴︽儑鐎ｎ収鍤婇柟顖氭嫅缁辨繈骞嬮弽顐ｇ函闁规亽鍎遍崹褰掓⒔閵堝棙锟ラ柡浣哥墢缁劑寮</text>
  </view>

  <view wx:if="{{error}}" class="notice notice-error">{{error}}</view>
  <view wx:if="{{loading}}" class="notice">婵繐绲藉﹢顏堝触鐏炵虎鍔勯柡鍫氬亾闁哄倹濯介惁搴∶圭€ｎ収鍞剁憸?..</view>

  <view wx:if="{{!results.length && !loading}}" class="paper-panel empty-panel">
    <text class="panel-title">鐟滅増鎸告晶鐘诲级閳ュ弶顐藉☉鎾愁儐閻ュ懘寮垫径搴敹鐟</text>
    <text class="panel-subtitle">闁告瑯鍨禍鎺戙€掗崨顖楁晞缂佹稒鐩埀顒€顧€缁辨繈骞嬮弽顐ゆ惣鐎垫澘鎳忛悥鏌ユ嚔閹惧瓨鐑﹀☉鎾筹梗缁卞爼寮幍顔界暠閻犲洤瀚粊瀵哥磼閹惧浜柕</text>
  </view>

  <view
    wx:for="{{results}}"
    wx:key="id"
    class="paper-panel record-sheet"
    data-id="{{item.id}}"
    bindtap="openDetail"
  >
    <view wx:if="{{managing}}" class="record-select-wrap" catchtap="onSelectRecord" data-id="{{item.id}}">
      <view class="record-select {{selectedIds.indexOf(item.id) !== -1 ? 'record-select-on' : ''}}">
        <text wx:if="{{selectedIds.indexOf(item.id) !== -1}}" class="record-select-mark">闁</text>
      </view>
    </view>

    <view class="record-stamp" style="background: {{item.scoreSoft}}; color: {{item.scoreColor}};">
      <text class="record-char">{{item.characterLabel}}</text>
      <text class="record-level">{{item.qualityLabel}}</text>
    </view>

    <view class="record-body">
      <view class="record-top">
        <view class="record-score-line">
          <text class="record-score" style="color: {{item.scoreColor}};">{{item.total_score}}</text>
          <text class="record-grade">{{item.qualityLabel}}</text>
        </view>
        <button
          class="record-delete"
          catchtap="deleteRecord"
          data-id="{{item.id}}"
          data-character="{{item.characterLabel}}"
          loading="{{deletingId === item.id}}"
        >
          闁告帞濞€濞?        </button>
      </view>

      <text class="record-time">{{item.timestamp}} / {{item.deviceLabel}} / {{item.scriptLabel}}</text>
      <text class="record-feedback">{{item.feedbackPreview}}</text>
      <text class="record-dimension">{{item.dimensionSummary}}</text>

      <view class="record-meta">
        <text class="meta-pill">OCR {{item.ocrText}}</text>
        <text class="meta-pill">閻犲洤瀚?{{item.qualityText}}</text>
        <text class="meta-pill">{{item.scriptBadgeText}}</text>
        <text wx:if="{{!item.scriptSupported}}" class="meta-pill script-warning">{{item.scriptStatusText}}</text>
      </view>
    </view>
  </view>
</view>
