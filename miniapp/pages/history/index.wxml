<view class="page-shell history-page">
  <view class="page-orb page-orb-a"></view>
  <view class="page-orb page-orb-b"></view>

  <view class="paper-panel hero-sheet">
    <view class="hero-head">
      <view class="hero-copy">
        <text class="eyebrow">InkPi Cloud</text>
        <text class="hero-title">评测卷宗</text>
        <text class="hero-subtitle">
          树莓派评测完成后，历史记录会自动同步到云端。这里展示的是自动 OCR + ONNX
          单链路的最新成绩。
        </text>
      </view>
      <button class="ghost-btn logout-btn" bindtap="logout">退出</button>
    </view>

    <view class="hero-meta">
      <text class="user-seal">{{userLabel}}</text>
      <view class="chip-row">
        <text class="meta-chip">最近刷新 {{lastUpdated || '暂未同步'}}</text>
        <text class="meta-chip">设备 {{summary.deviceCount}}</text>
      </view>
    </view>
  </view>

  <view class="summary-strip">
    <view class="summary-item">
      <text class="summary-label">总记录</text>
      <text class="summary-value">{{summary.total}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">最新得分</text>
      <text class="summary-value">{{summary.latestScore}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">平均得分</text>
      <text class="summary-value">{{summary.average}}</text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">最新记录</text>
    <text class="section-note">下拉刷新，或等待自动同步</text>
  </view>

  <view wx:if="{{error}}" class="notice notice-error">{{error}}</view>
  <view wx:if="{{loading}}" class="notice">正在同步最新评测记录...</view>

  <view wx:if="{{!results.length && !loading}}" class="paper-panel empty-panel">
    <text class="panel-title">还没有评测记录</text>
    <text class="panel-subtitle">
      树莓派完成一次评测并成功上传后，这里就会出现新的成绩单。
    </text>
  </view>

  <view
    wx:for="{{results}}"
    wx:key="id"
    class="paper-panel record-sheet"
    data-id="{{item.id}}"
    bindtap="openDetail"
  >
    <view class="record-stamp" style="background: {{item.scoreSoft}}; color: {{item.scoreColor}};">
      <text class="record-char">{{item.characterLabel}}</text>
      <text class="record-level">{{item.qualityLabel}}</text>
    </view>

    <view class="record-body">
      <view class="record-score-line">
        <text class="record-score" style="color: {{item.scoreColor}};">{{item.total_score}}</text>
        <text class="record-grade">{{item.qualityLabel}}</text>
      </view>

      <text class="record-time">{{item.timestamp}} / {{item.deviceLabel}}</text>
      <text class="record-feedback">{{item.feedbackPreview}}</text>

      <view class="record-meta">
        <text class="meta-pill">OCR {{item.ocrText}}</text>
        <text class="meta-pill">评级 {{item.qualityText}}</text>
      </view>
    </view>
  </view>
</view>
