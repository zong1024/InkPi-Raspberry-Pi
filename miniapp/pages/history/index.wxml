        <button class="ghost-btn stats-btn" bindtap="goStats">缂備胶鍠曢鍛婄▔椤撶偟濡</button>
        <button class="ghost-btn logout-btn" bindtap="logout">闂侇偀鍋撻柛</button>
      </view>
    </view>

    <view class="hero-meta">
