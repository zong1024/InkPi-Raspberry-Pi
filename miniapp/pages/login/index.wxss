.login-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-card {
  width: 100%;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
}

.login-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.inkpi-mark {
  display: inline-flex;
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f3e5d4;
  color: #7a4d30;
  font-size: 24rpx;
  font-weight: 700;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #5f4a37;
  font-weight: 600;
}

.input {
  height: 88rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #fbf7f1;
  border: 1rpx solid #dfcfbb;
  font-size: 28rpx;
  box-sizing: border-box;
}

.error-text {
  display: block;
  margin-bottom: 20rpx;
  color: #b13d31;
  font-size: 24rpx;
}

.login-btn {
  margin-top: 10rpx;
}
