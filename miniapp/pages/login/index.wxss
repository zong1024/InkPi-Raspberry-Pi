.login-page {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 24rpx;
}

.login-hero {
  position: relative;
  z-index: 1;
  padding: 24rpx 8rpx 8rpx;
}

.hero-brand {
  display: block;
  margin-top: 18rpx;
  font-size: 68rpx;
  line-height: 1.02;
  font-weight: 800;
  color: #2c2219;
  letter-spacing: 2rpx;
}

.hero-copy {
  display: block;
  margin-top: 22rpx;
  max-width: 620rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6e5a46;
}

.hero-points {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero-point {
  padding-left: 22rpx;
  border-left: 4rpx solid rgba(162, 98, 60, 0.42);
}

.hero-point-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #3a2d21;
}

.hero-point-text {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7b6752;
}

.login-panel {
  padding: 34rpx 30rpx 30rpx;
}

.panel-head {
  margin-bottom: 26rpx;
}

.demo-strip {
  margin-bottom: 28rpx;
  padding: 22rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(247, 239, 229, 0.92), rgba(241, 229, 212, 0.92));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.demo-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.demo-label {
  font-size: 22rpx;
  color: #8b735d;
}

.demo-value {
  font-size: 28rpx;
  color: #3b2f24;
  font-weight: 700;
}

.demo-btn {
  margin: 0;
  padding: 0 24rpx;
  min-width: 170rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.field-label {
  font-size: 25rpx;
  color: #64513f;
  font-weight: 700;
}

.field-input {
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.95);
  border: 1rpx solid rgba(201, 177, 149, 0.72);
  font-size: 28rpx;
  color: #2f251b;
  box-sizing: border-box;
}

.login-error {
  display: block;
  margin: 4rpx 0 12rpx;
  color: #b14b3e;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-btn {
  margin-top: 8rpx;
}
