page {
  min-height: 100%;
  background: #f8f5ef;
  color: #2b231b;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 252, 247, 0.96);
  border: 1rpx solid #e0d1bc;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(62, 45, 29, 0.08);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2419;
}

.section-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b6b59;
}

.primary-btn {
  background: linear-gradient(135deg, #b56f3f, #864b2d);
  color: #fff9f3;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-btn {
  background: #f3e6d3;
  color: #6b4c35;
  border-radius: 999rpx;
  border: 1rpx solid #d9c2a5;
  font-size: 28rpx;
  font-weight: 600;
}
